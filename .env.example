NEO4J_PASSWORD=voidcat_sovereign

# 4. MCP CONFIGURATION
SOVEREIGN_CONFIG_DIR=config
MCP_CONFIG_PATH=config/mcp_config.json

# 5. MCP & EXTERNAL TOOLS
BRAVE_SEARCH_API_KEY=your_brave_key
