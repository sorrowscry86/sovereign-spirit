# ============================================================================
# VOIDCAT RDC: SOVEREIGN STACK - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and customize values as needed
# DO NOT commit .env to version control
# ============================================================================

# ==========================================================================
# NEO4J CONFIGURATION
# ==========================================================================
NEO4J_AUTH=neo4j/voidcat_sovereign

# ==========================================================================
# POSTGRESQL CONFIGURATION
# ==========================================================================
POSTGRES_USER=voidcat
POSTGRES_PASSWORD=sovereign_spirit
POSTGRES_DB=voidcat_rdc

# ==========================================================================
# WEAVIATE CONFIGURATION
# ==========================================================================
# External embedding model endpoint (if using external embeddings)
# WEAVIATE_EMBEDDING_URL=http://localhost:11434/api/embeddings

# ==========================================================================
# OLLAMA CONFIGURATION (External - Not in Docker)
# ==========================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.2-q4_K_M

# ==========================================================================
# HEARTBEAT CONFIGURATION
# ==========================================================================
HEARTBEAT_INTERVAL_MS=90000
HEARTBEAT_JITTER_MS=15000
HEARTBEAT_MAX_TOKENS=75
HEARTBEAT_TEMPERATURE=0.6

# ==========================================================================
# MEMORY SYSTEM CONFIGURATION
# ==========================================================================
# Hot storage retention (days)
MEMORY_HOT_RETENTION_DAYS=7
# Warm storage retention (days)
MEMORY_WARM_RETENTION_DAYS=30
# Cold storage retention (days)
MEMORY_COLD_RETENTION_DAYS=90

# ==========================================================================
# SECURITY CONFIGURATION
# ==========================================================================
# API Key Authentication (disabled by default for development)
# Set to 'true' to require X-API-Key header on all requests
SOVEREIGN_API_KEY_ENABLED=false
# Generate a secure key: openssl rand -hex 32
SOVEREIGN_API_KEY=

# Rate Limiting (enabled by default)
SOVEREIGN_RATE_LIMIT_ENABLED=true
# Maximum requests per window
SOVEREIGN_RATE_LIMIT_REQUESTS=60
# Window duration in seconds
SOVEREIGN_RATE_LIMIT_WINDOW=60

# ==========================================================================
# AGENT CONFIGURATION
# ==========================================================================
# Comma-separated list of default agents to register on startup
SOVEREIGN_DEFAULT_AGENTS=echo,ryuzu,beatrice

# Pantheon profiles directory (for persona sync)
# PANTHEON_PROFILES_DIR=/path/to/profiles

# ==========================================================================
# LOGGING CONFIGURATION
# ==========================================================================
LOG_LEVEL=INFO
