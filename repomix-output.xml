import neo4j, { Driver, Session } from 'neo4j-driver';

export class GraphKnowledge {
  private driver: Driver;

  constructor() {
    this.driver = neo4j.driver(
      'bolt://localhost:7687',
      neo4j.auth.basic('neo4j', 'changeme')
    );
